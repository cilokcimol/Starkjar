# =====================================================
# STARKJAR — Environment Variables
# =====================================================
# Copy this file to .env.local for local dev
# Set these in Netlify Dashboard for production:
# Site Settings → Environment Variables
# =====================================================

# --- PRIVY (Authentication) ---
# Get from: https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here    # SECRET - only in Netlify Dashboard

# --- AVNU Paymaster (Gasless transactions) ---
# Get from: https://doc.avnu.fi/avnu-paymaster/introduction
AVNU_PAYMASTER_API_KEY=your_avnu_key_here      # SECRET - only in Netlify Dashboard

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://your-site.netlify.app
NEXT_PUBLIC_TIPPING_CONTRACT_ADDRESS=0x7a105e998b5e09b6a40b15a32bc1fc591f5748025d355e042259d659ab3c418
